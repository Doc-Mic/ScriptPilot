<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:ignore="TooDeepLayout,TooManyViews,UselessParent">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <include
            android:id="@+id/header"
            layout="@layout/include_screen_header" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/spacing_dashboard_h"
            android:paddingTop="@dimen/spacing_md"
            android:paddingEnd="@dimen/spacing_dashboard_h"
            android:paddingBottom="@dimen/spacing_xl">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="@dimen/spacing_lg">

                <TextView
                    android:id="@+id/textGreeting"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.ScriptPilot.GreetingHeadline"
                    tools:text="@string/layout_tools_greeting_preview" />

                <TextView
                    android:id="@+id/textGreetingSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="@string/home_greeting_subtitle"
                    android:textAppearance="@style/TextAppearance.ScriptPilot.BodyRelaxed"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/home_section_actions"
                android:textAppearance="@style/TextAppearance.ScriptPilot.SectionTitle" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:text="@string/home_section_workspace_sub"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <!-- Full-width workspace cards — single column, consistent row height -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTrends"
                    style="@style/SpCardHomeFeature"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_home_card_border_glow"
                        android:paddingStart="@dimen/spacing_md"
                        android:paddingTop="@dimen/home_feature_inner_padding_vertical"
                        android:paddingEnd="@dimen/spacing_md"
                        android:paddingBottom="@dimen/home_feature_inner_padding_vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    style="@style/SpLabelPill"
                                    android:text="@string/label_trending" />

                                <TextView
                                    style="@style/SpLabelPill"
                                    android:layout_marginStart="@dimen/spacing_xs"
                                    android:text="@string/label_ai_powered" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_sm"
                                android:baselineAligned="false"
                                android:gravity="center_vertical"
                                android:minHeight="@dimen/home_feature_row_min_height"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="@dimen/home_feature_icon_size"
                                    android:layout_height="@dimen/home_feature_icon_size"
                                    android:background="@drawable/bg_home_icon_circle"
                                    android:contentDescription="@string/content_desc_card_icon"
                                    android:padding="@dimen/spacing_sm"
                                    android:scaleType="centerInside"
                                    android:src="@drawable/ic_feature_trend"
                                    app:tint="?attr/colorOnPrimaryContainer" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/spacing_md"
                                    android:layout_weight="1"
                                    android:gravity="center_vertical"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:ellipsize="end"
                                        android:maxLines="1"
                                        android:text="@string/card_trends_title"
                                        android:textAppearance="@style/TextAppearance.ScriptPilot.CardTitle" />

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:ellipsize="end"
                                        android:maxLines="1"
                                        android:text="@string/card_trends_subtitle"
                                        android:textAppearance="?attr/textAppearanceBodyMedium"
                                        android:textColor="?attr/colorOnSurfaceVariant" />
                                </LinearLayout>

                                <ImageView
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:layout_marginStart="@dimen/spacing_sm"
                                    android:contentDescription="@string/content_desc_navigate"
                                    android:src="@drawable/ic_chevron_forward"
                                    app:tint="?attr/colorOnSurfaceVariant" />
                            </LinearLayout>
                        </LinearLayout>
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardIdea"
                    style="@style/SpCardHomeFeature"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/home_workspace_card_spacing">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_home_card_border_glow"
                        android:paddingStart="@dimen/spacing_md"
                        android:paddingTop="@dimen/home_feature_inner_padding_vertical"
                        android:paddingEnd="@dimen/spacing_md"
                        android:paddingBottom="@dimen/home_feature_inner_padding_vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    style="@style/SpLabelPill"
                                    android:text="@string/label_ai_powered" />

                                <TextView
                                    style="@style/SpLabelPill"
                                    android:layout_marginStart="@dimen/spacing_xs"
                                    android:text="@string/label_fast" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_sm"
                                android:baselineAligned="false"
                                android:gravity="center_vertical"
                                android:minHeight="@dimen/home_feature_row_min_height"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="@dimen/home_feature_icon_size"
                                    android:layout_height="@dimen/home_feature_icon_size"
                                    android:background="@drawable/bg_home_icon_circle"
                                    android:contentDescription="@string/content_desc_card_icon"
                                    android:padding="@dimen/spacing_sm"
                                    android:scaleType="centerInside"
                                    android:src="@drawable/ic_feature_idea"
                                    app:tint="?attr/colorOnPrimaryContainer" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/spacing_md"
                                    android:layout_weight="1"
                                    android:gravity="center_vertical"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:ellipsize="end"
                                        android:maxLines="1"
                                        android:text="@string/card_idea_title"
                                        android:textAppearance="@style/TextAppearance.ScriptPilot.CardTitle" />

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:ellipsize="end"
                                        android:maxLines="1"
                                        android:text="@string/card_idea_subtitle"
                                        android:textAppearance="?attr/textAppearanceBodyMedium"
                                        android:textColor="?attr/colorOnSurfaceVariant" />
                                </LinearLayout>

                                <ImageView
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:layout_marginStart="@dimen/spacing_sm"
                                    android:contentDescription="@string/content_desc_navigate"
                                    android:src="@drawable/ic_chevron_forward"
                                    app:tint="?attr/colorOnSurfaceVariant" />
                            </LinearLayout>
                        </LinearLayout>
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardScript"
                    style="@style/SpCardHomeFeature"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/home_workspace_card_spacing">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_home_card_border_glow"
                        android:paddingStart="@dimen/spacing_md"
                        android:paddingTop="@dimen/home_feature_inner_padding_vertical"
                        android:paddingEnd="@dimen/spacing_md"
                        android:paddingBottom="@dimen/home_feature_inner_padding_vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    style="@style/SpLabelPill"
                                    android:text="@string/label_creator_tool" />

                                <TextView
                                    style="@style/SpLabelPill"
                                    android:layout_marginStart="@dimen/spacing_xs"
                                    android:text="@string/label_ai_powered" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_sm"
                                android:baselineAligned="false"
                                android:gravity="center_vertical"
                                android:minHeight="@dimen/home_feature_row_min_height"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="@dimen/home_feature_icon_size"
                                    android:layout_height="@dimen/home_feature_icon_size"
                                    android:background="@drawable/bg_home_icon_circle"
                                    android:contentDescription="@string/content_desc_card_icon"
                                    android:padding="@dimen/spacing_sm"
                                    android:scaleType="centerInside"
                                    android:src="@drawable/ic_feature_script"
                                    app:tint="?attr/colorOnPrimaryContainer" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/spacing_md"
                                    android:layout_weight="1"
                                    android:gravity="center_vertical"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:ellipsize="end"
                                        android:maxLines="1"
                                        android:text="@string/card_script_title"
                                        android:textAppearance="@style/TextAppearance.ScriptPilot.CardTitle" />

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:ellipsize="end"
                                        android:maxLines="1"
                                        android:text="@string/card_script_subtitle"
                                        android:textAppearance="?attr/textAppearanceBodyMedium"
                                        android:textColor="?attr/colorOnSurfaceVariant" />
                                </LinearLayout>

                                <ImageView
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:layout_marginStart="@dimen/spacing_sm"
                                    android:contentDescription="@string/content_desc_navigate"
                                    android:src="@drawable/ic_chevron_forward"
                                    app:tint="?attr/colorOnSurfaceVariant" />
                            </LinearLayout>
                        </LinearLayout>
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardShorts"
                    style="@style/SpCardHomeFeature"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/home_workspace_card_spacing">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_home_card_border_glow"
                        android:paddingStart="@dimen/spacing_md"
                        android:paddingTop="@dimen/home_feature_inner_padding_vertical"
                        android:paddingEnd="@dimen/spacing_md"
                        android:paddingBottom="@dimen/home_feature_inner_padding_vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    style="@style/SpLabelPill"
                                    android:text="@string/label_fast" />

                                <TextView
                                    style="@style/SpLabelPill"
                                    android:layout_marginStart="@dimen/spacing_xs"
                                    android:text="@string/label_trending" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_sm"
                                android:baselineAligned="false"
                                android:gravity="center_vertical"
                                android:minHeight="@dimen/home_feature_row_min_height"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="@dimen/home_feature_icon_size"
                                    android:layout_height="@dimen/home_feature_icon_size"
                                    android:background="@drawable/bg_home_icon_circle"
                                    android:contentDescription="@string/content_desc_card_icon"
                                    android:padding="@dimen/spacing_sm"
                                    android:scaleType="centerInside"
                                    android:src="@drawable/ic_feature_shorts"
                                    app:tint="?attr/colorOnPrimaryContainer" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/spacing_md"
                                    android:layout_weight="1"
                                    android:gravity="center_vertical"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:ellipsize="end"
                                        android:maxLines="1"
                                        android:text="@string/card_shorts_title"
                                        android:textAppearance="@style/TextAppearance.ScriptPilot.CardTitle" />

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:ellipsize="end"
                                        android:maxLines="1"
                                        android:text="@string/card_shorts_subtitle"
                                        android:textAppearance="?attr/textAppearanceBodyMedium"
                                        android:textColor="?attr/colorOnSurfaceVariant" />
                                </LinearLayout>

                                <ImageView
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:layout_marginStart="@dimen/spacing_sm"
                                    android:contentDescription="@string/content_desc_navigate"
                                    android:src="@drawable/ic_chevron_forward"
                                    app:tint="?attr/colorOnSurfaceVariant" />
                            </LinearLayout>
                        </LinearLayout>
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSeo"
                    style="@style/SpCardHomeFeature"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/home_workspace_card_spacing">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_home_card_border_glow"
                        android:paddingStart="@dimen/spacing_md"
                        android:paddingTop="@dimen/home_feature_inner_padding_vertical"
                        android:paddingEnd="@dimen/spacing_md"
                        android:paddingBottom="@dimen/home_feature_inner_padding_vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    style="@style/SpLabelPill"
                                    android:text="@string/label_ai_powered" />

                                <TextView
                                    style="@style/SpLabelPill"
                                    android:layout_marginStart="@dimen/spacing_xs"
                                    android:text="@string/label_creator_tool" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_sm"
                                android:baselineAligned="false"
                                android:gravity="center_vertical"
                                android:minHeight="@dimen/home_feature_row_min_height"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="@dimen/home_feature_icon_size"
                                    android:layout_height="@dimen/home_feature_icon_size"
                                    android:background="@drawable/bg_home_icon_circle"
                                    android:contentDescription="@string/content_desc_card_icon"
                                    android:padding="@dimen/spacing_sm"
                                    android:scaleType="centerInside"
                                    android:src="@drawable/ic_feature_seo"
                                    app:tint="?attr/colorOnPrimaryContainer" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/spacing_md"
                                    android:layout_weight="1"
                                    android:gravity="center_vertical"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:ellipsize="end"
                                        android:maxLines="1"
                                        android:text="@string/card_seo_title"
                                        android:textAppearance="@style/TextAppearance.ScriptPilot.CardTitle" />

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:ellipsize="end"
                                        android:maxLines="1"
                                        android:text="@string/card_seo_subtitle"
                                        android:textAppearance="?attr/textAppearanceBodyMedium"
                                        android:textColor="?attr/colorOnSurfaceVariant" />
                                </LinearLayout>

                                <ImageView
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:layout_marginStart="@dimen/spacing_sm"
                                    android:contentDescription="@string/content_desc_navigate"
                                    android:src="@drawable/ic_chevron_forward"
                                    app:tint="?attr/colorOnSurfaceVariant" />
                            </LinearLayout>
                        </LinearLayout>
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/home_section_recent"
                    android:textAppearance="@style/TextAppearance.ScriptPilot.SectionTitle" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonViewAllProjects"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/action_view_all_projects" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerRecent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingBottom="@dimen/spacing_sm"
                tools:listitem="@layout/item_project_compact" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/emptyRecent"
                style="@style/Widget.Material3.CardView.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:visibility="gone"
                app:cardBackgroundColor="?attr/colorSurfaceVariant"
                app:cardCornerRadius="@dimen/card_corner_large"
                app:strokeColor="@color/card_home_stroke"
                app:strokeWidth="1dp"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_xl">

                    <ImageView
                        android:layout_width="@dimen/empty_recent_illustration_size"
                        android:layout_height="@dimen/empty_recent_illustration_size"
                        android:contentDescription="@string/content_desc_empty_projects"
                        android:src="@drawable/illustration_empty_projects" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:gravity="center"
                        android:text="@string/empty_recent_title"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:gravity="center"
                        android:text="@string/empty_recent_body"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonFirstProject"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="@string/action_create_first_project" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
