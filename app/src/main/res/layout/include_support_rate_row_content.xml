<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:minHeight="84dp"
    android:orientation="horizontal"
    android:padding="@dimen/spacing_md">
    <FrameLayout android:layout_width="48dp" android:layout_height="48dp" android:background="@drawable/bg_settings_icon">
        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:contentDescription="@null" android:src="@drawable/ic_star" app:tint="?attr/colorPrimary" />
    </FrameLayout>
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="@dimen/spacing_md" android:layout_weight="1" android:orientation="vertical">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/profile_rate_app" android:textAppearance="@style/TextAppearance.ScriptPilot.CardTitle" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/spacing_xs" android:text="@string/support_rate_subtitle" android:textAppearance="?attr/textAppearanceBodySmall" android:textColor="?attr/colorOnSurfaceVariant" />
    </LinearLayout>
    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_marginStart="@dimen/spacing_sm" android:contentDescription="@string/content_desc_navigate" android:src="@drawable/ic_chevron_forward" app:tint="?attr/colorOnSurfaceVariant" />
</LinearLayout>
